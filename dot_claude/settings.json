{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@1.19.0 --theme=custom --style=powerline"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "aloud-code@suzuki-toshihir0": true
  },
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "defaultMode": "auto"
  }
}
